{
  "name": "deepseek-self-learning-guide",
  "version": "2.0.0",
  "description": "Гайд по DeepSeek и самообучению на базе Diplodoc",
  "scripts": {
    "build": "yfm -i ./docs -o ./docs-html",
    "start": "yfm serve -i ./docs",
    "build:pdf": "yfm -i ./docs -o ./docs-pdf --pdf",
    "generate:pdf": "npx --yes @diplodoc/pdf-generator@latest -i ./docs-pdf",
    "pdf": "npm run build:pdf && npm run generate:pdf",
    "pdf:fix": "npm run build:pdf && npx --yes @diplodoc/pdf-generator@latest -i ./docs-pdf"
  },
  "dependencies": {
    "@diplodoc/cli": "^5.39.2"
  }
}